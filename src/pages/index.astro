---
import Layout from "@/layouts/Layout.astro";
import App from "@/components/App.astro";
---

<Layout title="Bienvenidos a IoCDB Share">
	<main class="mx-auto p-4 text-white text-lg">
		<h1
			class="text-6xl font-bold leading-none text-center [text-wrap:balance]"
		>
			Bienvenidos a
			<span
				class="bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent bg-[400%] bg-pos-0"
			>
				IoCDB Share
			</span>
		</h1>
		<App />
	</main>
</Layout>
